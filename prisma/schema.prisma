generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id            String   @id @default(cuid())
  userId        String
  title         String   @default("New Chat")
  model         String?
  systemPrompt  String?  @db.Text
  isPinned      Boolean  @default(false)
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())

  // Branching: `rootConversationId` points to the original conversation a branch
  // tree started from (null when this conversation IS the root). `parentConversationId`
  // + `branchFromMessageId` record the exact message this branch split off from.
  rootConversationId   String?
  parentConversationId String?
  branchFromMessageId  String?

  root     Conversation?  @relation("ConversationRoot", fields: [rootConversationId], references: [id], onDelete: Cascade)
  branches Conversation[] @relation("ConversationRoot")

  parent   Conversation?  @relation("ConversationParent", fields: [parentConversationId], references: [id], onDelete: SetNull)
  children Conversation[] @relation("ConversationParent")

  messages Message[]
  user     user      @relation(fields: [userId], references: [id])

  @@index([userId, lastMessageAt(sort: Desc)])
  @@index([userId, isPinned, lastMessageAt(sort: Desc)])
  @@index([rootConversationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum MessageStatus {
  PENDING // created before streaming finishes
  COMPLETE
  ERROR
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  role           MessageRole
  status         MessageStatus @default(COMPLETE)
  content        String        @db.Text
  parts          Json
  metadata       Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt(sort: Desc)])
}
